# ─────────────────────────────────────────────────────────────
# .gitignore — SMS Spam Classifier
# Goal: keep the repo small, reproducible, and free of secrets.
# ─────────────────────────────────────────────────────────────

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
*.egg
.eggs/
build/
dist/
.venv/
venv/
env/
ENV/
.mypy_cache/
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/
.nox/

# ── Secrets / local config ────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.crt
secrets.*
config.local.*

# ── Large / regenerable artifacts ─────────────────────────────
# Trained model binaries (joblib) — regenerate with train_all_models.py
artifacts/*.joblib
artifacts/*.pkl
artifacts/*.h5
artifacts/*.pt
artifacts/*.onnx

# SQLite database — regenerate by running the API once
artifacts/*.db
artifacts/*.sqlite
artifacts/*.sqlite3

# Generated plots — regenerate with train_all_models.py
artifacts/*.png
artifacts/*.jpg
artifacts/*.jpeg
artifacts/*.svg

# Generated reports — regenerate with train_all_models.py
artifacts/all_models_report.json

# ── Dataset (large, public, but keep repo lean) ───────────────
spam.csv
*.tsv
*.parquet

# ── IDE / OS noise ────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db
$RECYCLE.BIN/

# ── Logs ──────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pip-log.txt

# ── Jupyter / notebooks ───────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Misc ──────────────────────────────────────────────────────
*.bak
*.tmp
*.orig
*.rej
