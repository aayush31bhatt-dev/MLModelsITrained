# Auto-detect text files and normalize line endings.
* text=auto eol=lf

# Force bash scripts to use LF.
*.sh text eol=lf

# Batch/cmd scripts must use CRLF on Windows.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Python sources should use LF.
*.py text eol=lf

# Markdown and config files use LF.
*.md text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf

# Binary files — do not modify.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.joblib binary
*.pkl binary
*.db binary
*.sqlite binary
*.sqlite3 binary
*.zip binary
*.gz binary
*.tar binary
